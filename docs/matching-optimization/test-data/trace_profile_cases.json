        "emotions_should_include_any": ["不确定", "茫然", "焦虑"],
        "scenes_should_include_any": ["工作", "入职", "过渡期"],
        "central_pattern_policy": "可以描述计划被推迟后重新安排当下。",
        "representative_moment_id_must_be_one_of": ["m_t03_1", "m_t03_2"]
      },
      "forbidden_terms": ["人格", "潜意识", "创伤", "疗愈"],
      "tags": ["work", "transition"]
