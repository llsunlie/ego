{
  "schema_version": 1,
  "suite": "trace_profile_quality_baseline",
  "description": "P5 baseline cases for TraceProfile generation quality review.",
  "cases": [
    {
      "case_id": "trace_profile.t01.relationship_waiting",
      "title": "亲密关系里的主动与等待",
      "trace": {
        "id": "trace_profile_t01",
        "motivation": "direct",
        "moments": [
          {
            "id": "m_t01_1",
            "content": "我不想每次都是我先开口。"
          },
          {
            "id": "m_t01_2",
            "content": "但我又一直在等他发现。"
          }
        ]
      },
      "expected_quality": {
        "topic_should_be_about": ["关系", "主动", "等待"],
        "keywords_should_include_any": ["先开口", "等待", "主动"],
        "scenes_should_include_any": ["亲密关系", "关系"],
        "central_pattern_policy": "可以描述主动与等待的经历方式，但不要写成心理诊断。",
        "representative_moment_id_must_be_one_of": ["m_t01_1", "m_t01_2"]
      },
      "forbidden_terms": ["创伤", "潜意识", "依恋", "疗愈", "防御", "投射"],
      "tags": ["relationship", "central_pattern_present"]
    },
    {
      "case_id": "trace_profile.t02.daily_cooking",
      "title": "新的日常体验不应强行制造冲突",
      "trace": {
        "id": "trace_profile_t02",
        "motivation": "direct",
        "moments": [
          {
            "id": "m_t02_1",
            "content": "今天第一次认真做饭，发现切菜的时候心里很安静。"
          }
        ]
      },
      "expected_quality": {
        "topic_should_be_about": ["做饭", "烹饪", "生活"],
        "keywords_should_include_any": ["做饭", "切菜", "安静"],
        "emotions_should_include_any": ["安静"],
        "scenes_should_include_any": ["日常", "做饭", "独立生活"],
        "central_pattern_policy": "可以为空；如果不为空，只能描述生活细节与安顿感，不能制造矛盾。",
        "representative_moment_id_must_be_one_of": ["m_t02_1"]
      },
      "forbidden_terms": ["冲突", "创伤", "潜意识", "匮乏", "疗愈"],
      "tags": ["daily_life", "avoid_forced_conflict"]
    },
    {
      "case_id": "trace_profile.t03.work_delay",
