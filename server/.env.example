# ego server environment config
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
DATABASE_URL=postgres://ego:ego@localhost:5432/ego?sslmode=disable

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_EXP_HOURS=1
JWT_REFRESH_EXP_DAYS=30

# SMS Service
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_VALID_TIME=300
ALIYUN_SMS_INTERVAL=55

# Server
WEB_PORT=9080
WEB_TLS_PORT=9443
GRPC_PORT=9444

# Sparse recall (pg_trgm, no external service needed)
ECHO_SPARSE_RECALL_ENABLED=true
ECHO_SPARSE_RECALL_TOP_K=10
ECHO_HYBRID_RRF_K=60

# CORS: comma-separated allowed origins for web access
# Leave empty to deny all cross-origin requests (localhost auto-allowed in dev)
CORS_ALLOWED_ORIGINS=

# gRPC Reflection: set to "true" to enable gRPC server reflection.
# Disabled by default. Use grpcurl or grpcui locally for debugging.
GRPC_REFLECTION=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=.tmp/logs/server/server.log

# TLS (Let's Encrypt auto-cert, leave empty to disable)
TLS_DOMAIN=

# AI (SiliconFlow)
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1

AI_EMBEDDING_API_KEY=
AI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
AI_EMBEDDING_MODEL=BAAI/bge-m3
AI_EMBEDDING_DIM=1024
AI_CHAT_API_KEY=
AI_CHAT_BASE_URL=https://api.deepseek.com
AI_CHAT_MODEL=deepseek-v4-flash

# API 限流
RATELIMIT_AUTH_RATE=10            # 鉴权接口 tokens/sec
RATELIMIT_AUTH_BURST=20           # 鉴权接口 桶容量
RATELIMIT_PREAUTH_RATE=10         # 免鉴权接口 tokens/sec
RATELIMIT_PREAUTH_BURST=30        # 免鉴权接口 桶容量
RATELIMIT_MAX_BUCKETS=500         # 最大桶数量
RATELIMIT_CLEANUP_INTERVAL=60     # 桶清理间隔（秒）
RATELIMIT_BUCKET_TTL=300          # 空闲桶过期时间（秒）
