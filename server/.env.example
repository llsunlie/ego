# ego server environment config
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
DATABASE_URL=postgres://ego:ego@localhost:5432/ego?sslmode=disable

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXP_HOURS=720

# SMS Service
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_VALID_TIME=300
ALIYUN_SMS_INTERVAL=55

# Server
WEB_PORT=9080
WEB_TLS_PORT=9443
GRPC_PORT=9444

# Elasticsearch sparse search
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ECHO_SPARSE_RECALL_ENABLED=true
ECHO_SPARSE_RECALL_TOP_K=10
ECHO_HYBRID_RRF_K=60

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=.tmp/logs/server/server.log

# TLS (Let's Encrypt auto-cert, leave empty to disable)
TLS_DOMAIN=

# AI (SiliconFlow)
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1

AI_EMBEDDING_API_KEY=
AI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
AI_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
AI_CHAT_API_KEY=
AI_CHAT_BASE_URL=https://api.deepseek.com
AI_CHAT_MODEL=deepseek-v4-flash
