# ego server environment config
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
DATABASE_URL=postgres://ego:ego@localhost:5432/ego?sslmode=disable

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXP_HOURS=720

# Server
PORT=9443
WEB_PORT=9080

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=stdout

# AI (SiliconFlow)
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
AI_CHAT_MODEL=deepseek-ai/DeepSeek-V3
